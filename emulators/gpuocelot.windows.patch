diff --git a/ocelot/ThirdParty/cuda-fatbin-decompression/fatbin-decompress.c b/ocelot/ThirdParty/cuda-fatbin-decompression/fatbin-decompress.c
index 57ae547..6f7d0bb 100644
--- a/ocelot/ThirdParty/cuda-fatbin-decompression/fatbin-decompress.c
+++ b/ocelot/ThirdParty/cuda-fatbin-decompression/fatbin-decompress.c
@@ -11,8 +11,27 @@
 #include <stdlib.h>
 #include <errno.h>
 #include <string.h>
+#ifdef _WIN32
+#include <BaseTsd.h>
+#include <stdarg.h>
+typedef SSIZE_T ssize_t;
+static int asprintf(char** str, const char* fmt, ...) {
+	va_list ap, ap2;
+	va_start(ap, fmt);
+	va_copy(ap2, ap);
+	int len = vsnprintf(NULL, 0, fmt, ap);
+	va_end(ap);
+	if (len < 0) { va_end(ap2); return -1; }
+	*str = (char*)malloc((size_t)len + 1);
+	if (!*str) { va_end(ap2); return -1; }
+	int r = vsnprintf(*str, (size_t)len + 1, fmt, ap2);
+	va_end(ap2);
+	return r;
+}
+#else
 #include <fcntl.h>
 #include <unistd.h>
+#endif
 
 #include "fatbin-decompress.h"
 #include "utils.h"
