+}
+
+CUresult Function(cuDevicePrimaryCtxRetain)(CUcontext *pctx, CUdevice dev) {
+	trace();
+	RETURN( CudaApi::get()->cuCtxCreate(pctx, 0, dev) );
+}
+CUresult Function(cuDevicePrimaryCtxRelease)(CUdevice dev) {
+	trace();
+	return CUDA_SUCCESS;
+}
+
+CUresult Function(cuGetErrorName)(CUresult error, const char **pStr) {
+	if (pStr) *pStr = (error == CUDA_SUCCESS) ? "CUDA_SUCCESS" : "CUDA_ERROR";
+	return CUDA_SUCCESS;
+}
+CUresult Function(cuGetErrorString)(CUresult error, const char **pStr) {
+	if (pStr) *pStr = (error == CUDA_SUCCESS) ? "no error" : "CUDA error (ocelot emulator)";
+	return CUDA_SUCCESS;
+}
+
+// Emulation is synchronous: run callbacks inline
+CUresult Function(cuLaunchHostFunc)(CUstream hStream, OcelotHostFn fn, void *userData) {
