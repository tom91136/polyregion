@@ -68,6 +71,39 @@
 // shared object or to invoke Ocelot's Driver API frontend
 typedef cuda::CudaDriverInterface CudaApi;
 
+// Absent from this header's cuda.h
+typedef void (*OcelotHostFn)(void *userData);
+typedef void (*OcelotStreamCallback)(CUstream, CUresult, void *);
+
+// strip .param attributes (.ptr/.align etc.) the PTX parser rejects
+static std::string sanitisePtxParams(const void *image) {
+	const char *ptx = static_cast<const char *>(image);
+	std::string in(ptx ? ptx : ""), out;
+	out.reserve(in.size());
+	size_t pos = 0;
+	while (pos < in.size()) {
+		size_t eol = in.find('\n', pos);
+		if (eol == std::string::npos) eol = in.size();
+		std::string line = in.substr(pos, eol - pos);
+		if (line.find(".param") != std::string::npos) {
+			for (const char *tok : {" .ptr", " .global", " .const", " .shared", " .local"}) {
+				size_t p;
+				while ((p = line.find(tok)) != std::string::npos) line.erase(p, std::strlen(tok));
+			}
+			size_t p;
+			while ((p = line.find(" .align ")) != std::string::npos) {
+				size_t q = p + 8;
+				while (q < line.size() && std::isdigit((unsigned char)line[q])) q++;
+				line.erase(p, q - p);
+			}
+		}
+		out += line;
+		if (eol < in.size()) out += '\n';
+		pos = eol + 1;
+	}
+	return out;
+}
