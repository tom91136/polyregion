+// modern Driver API entry points cuew resolves, mapped onto the legacy frontend
+CUresult Function(cuLaunchKernel)(CUfunction f,
+	unsigned int gridDimX, unsigned int gridDimY, unsigned int gridDimZ,
+	unsigned int blockDimX, unsigned int blockDimY, unsigned int blockDimZ,
+	unsigned int sharedMemBytes, CUstream hStream,
+	void **kernelParams, void **extra) {
+	trace();
+	ir::PTXKernel *kernel = reinterpret_cast<ir::PTXKernel *>(f);
+	if (!kernel) return CUDA_ERROR_INVALID_HANDLE;
+	CudaApi *api = CudaApi::get();
+	CUresult r;
+	if ((r = api->cuFuncSetBlockShape(f, (int)blockDimX, (int)blockDimY, (int)blockDimZ)) != CUDA_SUCCESS) return r;
+	if (sharedMemBytes && (r = api->cuFuncSetSharedSize(f, sharedMemBytes)) != CUDA_SUCCESS) return r;
+	unsigned int offset = 0, i = 0;
+	for (ir::Kernel::ParameterVector::const_iterator p = kernel->arguments.begin();
+		p != kernel->arguments.end(); ++p, ++i) {
+		unsigned int align = p->getAlignment();
+		unsigned int size = p->getSize();
+		if (align > 1) offset = (offset + align - 1) & ~(align - 1);
+		void *src = (kernelParams ? kernelParams[i] : 0);
+		if (src && (r = api->cuParamSetv(f, (int)offset, src, size)) != CUDA_SUCCESS) return r;
+		offset += size;
+	}
+	if ((r = api->cuParamSetSize(f, offset)) != CUDA_SUCCESS) return r;
+	// Legacy launch grid is 2-D; fold z into the height
+	return api->cuLaunchGrid(f, (int)gridDimX, (int)(gridDimY * (gridDimZ ? gridDimZ : 1)));
+}
+
+CUresult Function(cuMemAllocManaged)(CUdeviceptr *dptr, size_t bytesize, unsigned int flags) {
