# Ryzen 9 7950X iGPU (gfx1036) + RTX 4090 (sm_89). spirv64_kernel/hip disabled: no SPIRV
# runtime on this host, and HIP requires the Linux toolchain (use hsa@gfx1036).
export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:cuda@sm_89
POLYREGION_TEST_TARGETS+=:hip@gfx1036
POLYREGION_TEST_TARGETS+=:host@native
