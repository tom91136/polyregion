# NVIDIA RTX 4060 Ti, AMD Radeon (gfx1036), Intel Arc A750


export RUSTICL_ENABLE=iris,radeonsi,llvmpipe
#export RUSTICL_FEATURES=fp64 # currently broken currently
# XXX: spirv64_kernel needs SVM, the harness forces SVM-off only for opencl1_1 and Rusticl targets

export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:host@native!host@*
POLYREGION_TEST_TARGETS+=:cuda@sm_89!cuda@*
POLYREGION_TEST_TARGETS+=:hsa@gfx1036!hsa@*
POLYREGION_TEST_TARGETS+=:hip@gfx1036!hip@*

POLYREGION_TEST_TARGETS+=:spirv64_kernel@!spirv64_kernel@Intel*SPIR-V*
POLYREGION_TEST_TARGETS+=:spirv64_kernel@!spirv64_kernel@rusticl:*AMD*SPIR-V*
POLYREGION_TEST_TARGETS+=:spirv64_kernel@!spirv64_kernel@rusticl:*Intel*SPIR-V*
POLYREGION_TEST_TARGETS+=:spirv64_kernel@!spirv64_kernel@rusticl:*llvmpipe*SPIR-V*

POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@Intel*source*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@AMD*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@*NVIDIA*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@rusticl:*AMD*source*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@rusticl:*Intel*source*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@rusticl:*llvmpipe*source*

POLYREGION_TEST_TARGETS+=:spirv_glcompute@!spirv_glcompute@*AMD*
POLYREGION_TEST_TARGETS+=:spirv_glcompute@!spirv_glcompute@*Intel*
POLYREGION_TEST_TARGETS+=:spirv_glcompute@!spirv_glcompute@*NVIDIA*
POLYREGION_TEST_TARGETS+=:spirv_glcompute@!spirv_glcompute@*llvmpipe*


export POLYINVOKE_TEST_TARGETS=
POLYINVOKE_TEST_TARGETS+=:host@native
POLYINVOKE_TEST_TARGETS+=:c11@native
POLYINVOKE_TEST_TARGETS+=:cuda@sm_89
POLYINVOKE_TEST_TARGETS+=:hsa@gfx1036
POLYINVOKE_TEST_TARGETS+=:hip@gfx1036
POLYINVOKE_TEST_TARGETS+=:spirv64_kernel@intel
POLYINVOKE_TEST_TARGETS+=:opencl1_1@intel
POLYINVOKE_TEST_TARGETS+=:opencl1_1@amd
POLYINVOKE_TEST_TARGETS+=:opencl1_1@nvidia
POLYINVOKE_TEST_TARGETS+=:opencl1_1@rusticl
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@intel
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@nvidia
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@amd
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@llvmpipe
POLYINVOKE_TEST_TARGETS+=:level_zero@
