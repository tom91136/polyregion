# NVIDIA RTX 4060 Ti, AMD Radeon (gfx1036), Intel Arc A750
# Disabled: hip@gfx1036 (HIP can't dispatch clang-OpenCL hsaco; use hsa@gfx1036 instead),
# spirv_glcompute@*, opencl1_1@* (need advanced kernel rewriting), c11@native (no runtime
# cc step; use host@native for CPU).
export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:cuda@sm_89
POLYREGION_TEST_TARGETS+=:hsa@gfx1036
# Pin to @intel: Arc A750 exposes SPIRV via IGC and Rusticl if installed, but Rusticl's program
# path mishandles indirect SVM and yields wrong reductions
POLYREGION_TEST_TARGETS+=:spirv64_kernel@intel
POLYREGION_TEST_TARGETS+=:host@native
