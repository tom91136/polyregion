# NVIDIA RTX 4060 Ti, AMD Radeon (gfx1036), Intel Arc A750

# Codegen tests (polyc/polycpp/polyfc/polyc-benchmarks). Some targets need toolchain/runtime
# wiring the test harness doesn't have yet, so they're left out here even though polyinvoke can
# happily dispatch them at runtime (those go in POLYINVOKE_TEST_TARGETS below).
# FIXME spirv_glcompute@* (need arg flattening)
# FIXME opencl1_1@        (need arg flattening)
# FIXME c11@native        (no runtime cc step; use host@native for CPU)
# FIXME level_zero@       (no codegen-side test driver, runtime-only)
export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:host@native
POLYREGION_TEST_TARGETS+=:cuda@sm_89
POLYREGION_TEST_TARGETS+=:hsa@gfx1036
POLYREGION_TEST_TARGETS+=:hip@gfx1036
# Pin to @intel: Arc A750 exposes SPIRV via IGC and Rusticl if installed, but Rusticl's program
# path mishandles indirect SVM and yields wrong reductions.
POLYREGION_TEST_TARGETS+=:spirv64_kernel@intel

# Runtime tests (polyinvoke-tests). Wider set: the runtime can dispatch pre-built kernel images
# for c11/spirv_glcompute/opencl1_1/level_zero without a codegen step.
export POLYINVOKE_TEST_TARGETS=
POLYINVOKE_TEST_TARGETS+=:host@native
POLYINVOKE_TEST_TARGETS+=:c11@native
POLYINVOKE_TEST_TARGETS+=:cuda@sm_89
POLYINVOKE_TEST_TARGETS+=:hsa@gfx1036
POLYINVOKE_TEST_TARGETS+=:hip@gfx1036
POLYINVOKE_TEST_TARGETS+=:spirv64_kernel@intel
POLYINVOKE_TEST_TARGETS+=:opencl1_1@
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@*
POLYINVOKE_TEST_TARGETS+=:level_zero@
