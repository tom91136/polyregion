# Ryzen AI 9 HX 370 + Radeon 890M (gfx1150)

# Codegen tests (polyc/polycpp/polyfc).
export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:host@native
POLYREGION_TEST_TARGETS+=:cuda@sm_120
POLYREGION_TEST_TARGETS+=:hsa@gfx1150
POLYREGION_TEST_TARGETS+=:hip@gfx1150

# Runtime tests (polyinvoke-tests).
export POLYINVOKE_TEST_TARGETS=
POLYINVOKE_TEST_TARGETS+=:cuda@sm_120
POLYINVOKE_TEST_TARGETS+=:host@native
POLYINVOKE_TEST_TARGETS+=:c11@native
POLYINVOKE_TEST_TARGETS+=:hsa@gfx1150
POLYINVOKE_TEST_TARGETS+=:hip@gfx1150
POLYINVOKE_TEST_TARGETS+=:opencl1_1@
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@*
