# riscv64 CPU + PowerVR BXM Vulkan/OpenCL GPU.

# Codegen tests (polyc/polycpp/polyfc).
export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:host@native!host@*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@*
POLYREGION_TEST_TARGETS+=:spirv_glcompute@!spirv_glcompute@*

# Runtime tests (polyinvoke-tests).
export POLYINVOKE_TEST_TARGETS=
POLYINVOKE_TEST_TARGETS+=:host@native
POLYINVOKE_TEST_TARGETS+=:c11@native
POLYINVOKE_TEST_TARGETS+=:opencl1_1@*
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@*
