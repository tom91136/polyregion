# Apple M4 Mac mini. CPU + Apple GPU via Metal

# Codegen tests (polyc/polycpp/polyfc).
# FIXME metal@host       (need arg flattening)
# FIXME opencl1_1@apple  (need arg flattening; no SVM in Apple's OpenCL 1.2)
export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:host@apple-m4

# Runtime tests (polyinvoke-tests).
export POLYINVOKE_TEST_TARGETS=
POLYINVOKE_TEST_TARGETS+=:metal@host
POLYINVOKE_TEST_TARGETS+=:opencl1_1@apple
POLYINVOKE_TEST_TARGETS+=:host@apple-m4
POLYINVOKE_TEST_TARGETS+=:c11@apple-m4
