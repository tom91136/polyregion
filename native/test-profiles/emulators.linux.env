# gpuocelot, lavapipe, swiftshader, rusticl, pocl

# Codegen tests (polyc/polycpp/polyfc).
export POLYREGION_TEST_TARGETS=
POLYREGION_TEST_TARGETS+=:host@native!host@*
POLYREGION_TEST_TARGETS+=:cuda@sm_35!cuda@*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@rusticl:*source*
POLYREGION_TEST_TARGETS+=:opencl1_1@!opencl1_1@*Portable*source*
POLYREGION_TEST_TARGETS+=:spirv64_kernel@!spirv64_kernel@rusticl:*SPIR-V*
POLYREGION_TEST_TARGETS+=:spirv64_kernel@!spirv64_kernel@*Portable*SPIR-V*
POLYREGION_TEST_TARGETS+=:spirv_glcompute@!spirv_glcompute@*llvmpipe*
POLYREGION_TEST_TARGETS+=:spirv_glcompute@!spirv_glcompute@*SwiftShader*

# Runtime tests (polyinvoke-tests).
export POLYINVOKE_TEST_TARGETS=
POLYINVOKE_TEST_TARGETS+=:host@native
POLYINVOKE_TEST_TARGETS+=:cuda@sm_35
POLYINVOKE_TEST_TARGETS+=:opencl1_1@rusticl
POLYINVOKE_TEST_TARGETS+=:opencl1_1@Portable
POLYINVOKE_TEST_TARGETS+=:spirv64_kernel@rusticl
POLYINVOKE_TEST_TARGETS+=:spirv64_kernel@Portable
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@llvmpipe
POLYINVOKE_TEST_TARGETS+=:spirv_glcompute@SwiftShader
