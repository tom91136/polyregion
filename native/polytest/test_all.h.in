#pragma once

#include <cstdlib>
#include <string>
#include <vector>

#include "llvm/Support/FileSystem.h"
#include "llvm/Support/Path.h"

#include "polyregion/env_keys.h"

namespace {
inline std::string envOr(const char *name, const char *fallback) {
  if (const char *v = std::getenv(name)) return std::string(v);
  return std::string(fallback);
}

inline std::vector<std::string> testFilesFromEnv(const char *dirEnv, std::vector<std::string> fallback) {
  if (const char *d = std::getenv(dirEnv)) {
    std::vector<std::string> out;
    std::error_code ec;
    for (llvm::sys::fs::recursive_directory_iterator it(d, ec, /*follow_symlinks*/ false), end; it != end && !ec;
         it.increment(ec)) {
      if (!llvm::sys::fs::is_regular_file(it->path())) continue;
      const auto name = llvm::sys::path::filename(it->path());
      const auto ext = llvm::sys::path::extension(it->path());
      if (name.starts_with("check_") && (ext == ".cpp" || ext == ".f95")) out.emplace_back(it->path());
    }
    if (!out.empty()) return out;
  }
  return fallback;
}
} // namespace

static const std::string BinaryDir = envOr(polyregion::env::PolytestBinaryDir, "@POLYTEST_BINARY_DIR@");
static const std::string WorkDir = envOr(polyregion::env::PolytestWorkDir, "@POLYTEST_CACHE_DIR@");
static const std::vector<std::string> TestFiles =
    testFilesFromEnv(polyregion::env::PolytestFilesDir, { @POLYTEST_INPUT_FILES@ });
static const std::string Driver = envOr(polyregion::env::PolytestDriver, "@POLYTEST_DRIVER@");
static const std::string Lib = envOr(polyregion::env::PolytestLib, "@POLYTEST_LIB@");
static const std::string LibraryPath = envOr(polyregion::env::PolytestLibraryPath, "@POLYTEST_LIBRARY_PATH@");
static const std::string Include = envOr(polyregion::env::PolytestInclude, "@POLYTEST_INCLUDE@");
