#pragma once

#include <cstdlib>
#include <filesystem>
#include <string>
#include <vector>

namespace {
inline std::string envOr(const char *name, const char *fallback) {
  if (const char *v = std::getenv(name)) return std::string(v);
  return std::string(fallback);
}

inline std::vector<std::string> testFilesFromEnv(const char *dirEnv, std::vector<std::string> fallback) {
  if (const char *d = std::getenv(dirEnv)) {
    std::vector<std::string> out;
    std::error_code ec;
    for (auto &e : std::filesystem::recursive_directory_iterator(d, ec)) {
      if (!e.is_regular_file()) continue;
      auto name = e.path().filename().string();
      auto ext = e.path().extension().string();
      if (name.rfind("check_", 0) == 0 && (ext == ".cpp" || ext == ".f95")) out.push_back(e.path().string());
    }
    if (!out.empty()) return out;
  }
  return fallback;
}
} // namespace

static const std::string BinaryDir = envOr("POLYTEST_BINARY_DIR", "@POLYCPP_TEST_BINARY_DIR@");
static const std::vector<std::string> TestFiles =
    testFilesFromEnv("POLYTEST_FILES_DIR", { @POLYCPP_TEST_INPUT_FILES@ });
static const std::string ClangDriver = envOr("POLYTEST_CLANG_DRIVER", "@POLYCPP_CLANG_DRIVER@");
static const std::string PolySTLLib = envOr("POLYTEST_POLYSTL_LIB", "@POLYCPP_POLYSTL_LIB@");
static const std::string PolySTLLDLibraryPath = envOr("POLYTEST_POLYSTL_LIBRARY_PATH", "@POLYCPP_POLYSTL_LIBRARY_PATH@");
static const std::string PolySTLInclude = envOr("POLYTEST_POLYSTL_INCLUDE", "@POLYCPP_POLYSTL_INCLUDE@");
