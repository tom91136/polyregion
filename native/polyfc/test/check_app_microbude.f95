#define CHECK_PPWI 1
#endif
#define PPWI CHECK_PPWI

module fasten
  implicit none

  integer, parameter :: INT32 = selected_int_kind(9)
  integer, parameter :: INT64 = selected_int_kind(18)
  integer, parameter :: REAL32 = selected_real_kind(p = 6, r = 37)
  integer, parameter :: REAL64 = selected_real_kind(p = 15, r = 307)
  integer, parameter :: STDOUT = 6

  real(REAL32), parameter :: zero = 0.0
  real(REAL32), parameter :: quarter = 0.25
  real(REAL32), parameter :: half = 0.5
  real(REAL32), parameter :: one = 1.0
  real(REAL32), parameter :: two = 2.0
  real(REAL32), parameter :: four = 4.0
  real(REAL32), parameter :: cnstnt = 45.0
  real(REAL32), parameter :: hardness = 38.0
  real(REAL32), parameter :: npnpdist = 5.5
  real(REAL32), parameter :: nppdist = 1.0

  integer(INT32), parameter :: hbtype_f = 70
  integer(INT32), parameter :: hbtype_e = 69

  type Atom
    real(REAL32) :: x, y, z
    integer(INT32) :: type
  end type

  type FFParams
    integer(INT32) :: hbtype
    real(REAL32) :: radius
    real(REAL32) :: hphb
    real(REAL32) :: elsc
  end type

contains

  pure subroutine fasten_main(group, nposes, natlig, natpro, protein, ligand, xforms, forcefield, energies)
    integer, intent(in) :: group, nposes, natlig, natpro
    type(Atom), intent(in) :: protein(natpro), ligand(natlig)
    real(REAL32), intent(in) :: xforms(6, nposes)
    type(FFParams), intent(in) :: forcefield(:)
    real(REAL32), intent(inout) :: energies(nposes)
    real(REAL32) :: xform(4, 3, PPWI)
    real(REAL32) :: etot(PPWI)
    integer :: l, il, ip, ix
    real(REAL32) :: sx, cx, sy, cy, sz, cz, x, y, z
    real(REAL32) :: distij, distbb, radij, r_radij
    real(REAL32) :: elcdst, elcdst1, chrg_init, chrg_e, neg_chrg_e
    real(REAL32) :: distdslv, r_distdslv, p_hphb, l_hphb, dslv_init, dslv_e, coeff
    real(REAL32) :: lpos_x(PPWI), lpos_y(PPWI), lpos_z(PPWI)
    type(Atom) :: l_atom, p_atom
    type(FFParams) :: l_params, p_params
    logical :: lhphb_ltz, lhphb_gtz, phphb_ltz, phphb_gtz, phphb_nz, type_e, zone1
    do l = 1, PPWI
      ix = (group - 1) * PPWI + l
      sx = sin(xforms(1, ix)); cx = cos(xforms(1, ix))
      sy = sin(xforms(2, ix)); cy = cos(xforms(2, ix))
      sz = sin(xforms(3, ix)); cz = cos(xforms(3, ix))
      xform(1, 1, l) = cy * cz; xform(2, 1, l) = sx * sy * cz - cx * sz; xform(3, 1, l) = cx * sy * cz + sx * sz
      xform(4, 1, l) = xforms(4, ix); xform(1, 2, l) = cy * sz; xform(2, 2, l) = sx * sy * sz + cx * cz
      xform(3, 2, l) = cx * sy * sz - sx * cz; xform(4, 2, l) = xforms(5, ix)
      xform(1, 3, l) = -sy; xform(2, 3, l) = sx * cy; xform(3, 3, l) = cx * cy
      xform(4, 3, l) = xforms(6, ix); etot(l) = zero
    end do
    do il = 1, natlig
      l_atom = ligand(il); l_params = forcefield(l_atom%type + 1)
      lhphb_ltz = l_params%hphb < zero; lhphb_gtz = l_params%hphb > zero
      do l = 1, PPWI
        lpos_x(l) = xform(4, 1, l) + l_atom%x * xform(1, 1, l) + l_atom%y * xform(2, 1, l) + l_atom%z * xform(3, 1, l)
        lpos_y(l) = xform(4, 2, l) + l_atom%x * xform(1, 2, l) + l_atom%y * xform(2, 2, l) + l_atom%z * xform(3, 2, l)
        lpos_z(l) = xform(4, 3, l) + l_atom%x * xform(1, 3, l) + l_atom%y * xform(2, 3, l) + l_atom%z * xform(3, 3, l)
      end do
      do ip = 1, natpro
        p_atom = protein(ip); p_params = forcefield(p_atom%type + 1)
        radij = p_params%radius + l_params%radius; r_radij = one / radij
        elcdst = merge(four, two, p_params%hbtype == hbtype_f .and. l_params%hbtype == hbtype_f)
        elcdst1 = merge(quarter, half, p_params%hbtype == hbtype_f .and. l_params%hbtype == hbtype_f)
        type_e = p_params%hbtype == hbtype_e .or. l_params%hbtype == hbtype_e
        phphb_ltz = p_params%hphb < zero; phphb_gtz = p_params%hphb > zero; phphb_nz = p_params%hphb /= zero
        p_hphb = p_params%hphb * merge(-one, one, phphb_ltz .and. lhphb_gtz)
        l_hphb = l_params%hphb * merge(-one, one, phphb_gtz .and. lhphb_ltz)
        if (phphb_ltz) then
          distdslv = merge(npnpdist, nppdist, lhphb_ltz)
        else
          distdslv = merge(nppdist, -huge(zero), lhphb_ltz)
        end if
        r_distdslv = one / distdslv; chrg_init = l_params%elsc * p_params%elsc; dslv_init = p_hphb + l_hphb
        do l = 1, PPWI
          x = lpos_x(l) - p_atom%x; y = lpos_y(l) - p_atom%y; z = lpos_z(l) - p_atom%z
          distij = sqrt(x * x + y * y + z * z)
          distbb = distij - radij
          zone1 = (distbb < zero)
          etot(l) = etot(l) + (one - (distij * r_radij)) * merge(two * hardness, zero, zone1)
          chrg_e = chrg_init * merge(one, (one - distbb * elcdst1), zone1) * merge(one, zero, distbb < elcdst)
          neg_chrg_e = -abs(chrg_e)
          chrg_e = merge(neg_chrg_e, chrg_e, type_e)
          etot(l) = etot(l) + chrg_e * cnstnt
          coeff = one - (distbb * r_distdslv)
          dslv_e = dslv_init * merge(one, zero, distbb < distdslv .and. phphb_nz)
          dslv_e = dslv_e * merge(one, coeff, zone1)
          etot(l) = etot(l) + dslv_e
        end do
      end do
    end do
    do l = 1, PPWI; ix = (group - 1) * PPWI + l; energies(ix) = etot(l) * half; end do
  end subroutine fasten_main

  subroutine run(iter, nposes, natlig, natpro, protein, ligand, poses, forcefield)
    integer, intent(in) :: iter, nposes, natlig, natpro
    type(Atom), intent(in) :: protein(natpro), ligand(natlig)
    real(REAL32), intent(in) :: poses(6, nposes)
    type(FFParams), intent(in) :: forcefield(:)
    real(REAL32), allocatable :: energies(:)
    real(REAL64) :: t1, t2, tavg, timings(iter - 1)
    integer :: i, group, ngroups
    allocate(energies(nposes))
    ngroups = nposes / PPWI
    do i = 1, iter
      call cpu_time(t1)
      do concurrent (group = 1 : ngroups)
        call fasten_main(group, nposes, natlig, natpro, protein, ligand, poses, forcefield, energies)
      end do
      call cpu_time(t2)
      if (i .gt. 1) timings(i - 1) = t2 - t1
    end do
    tavg = sum(timings) / (iter - 1)
#ifndef CHECK_SUMMARY_ONLY
    write(STDOUT, '(i4, f9.5, f12.5, f12.5, f18.5)') PPWI, minval(timings), maxval(timings), tavg, energies(1)
#else
    ! XXX Round at print time so libm/libdevice ULP drift doesn't flip the last displayed digit;
    ! f0.2 for energies and i0 for checksum leave ~20x margin over observed cross-platform drift.
    write(STDOUT, '(a)', advance = "no") "Energies"
    do i = 1, min(16, nposes)
      write(STDOUT, '(1x, f0.2)', advance = "no") &
        real(nint(real(energies(i), REAL64) * 100.0_REAL64), REAL64) / 100.0_REAL64
    end do
    block
      real(REAL64) :: checksum
      checksum = 0.0_REAL64
      do i = 1, nposes
        checksum = checksum + real(energies(i), REAL64)
      end do
      write(STDOUT, '(1x, a, 1x, i0)', advance = "no") "Checksum", nint(checksum)
    end block
#endif
    deallocate(energies)
  end subroutine run

end module fasten

