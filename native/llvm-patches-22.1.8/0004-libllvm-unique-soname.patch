From 0000000000000000000000000000000000000002 Mon Sep 17 00:00:00 2001
From: polyregion <noreply@polyregion>
Date: Sat, 7 Jun 2026 00:00:00 +0000
Subject: [PATCH] [llvm-shlib] unique OUTPUT_NAME so the bundled libLLVM never
 collides with a system libLLVM

The bundled libLLVM ships the same soname (libLLVM.so.<major>.<minor>) as a
distro's libLLVM. When a polyregion process dlopens a driver that itself links
the system libLLVM - a Mesa Vulkan ICD (lavapipe/RADV) is the common case - the
loader binds that driver to our already-loaded bundle (soname match). Our bundle
is built without RTTI and (here) under a private symbol-version, so the driver
fails with undefined `_ZTI...`/version errors, or the two LLVMs clash on the
shared cl::opt registry. Renaming our libLLVM frees the `libLLVM.so` soname for
the system copy; paired with LLVM_SHLIB_SYMBOL_VERSION=POLYREGION_LLVM the two
are fully independent in one process.
---
 llvm/tools/llvm-shlib/CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/llvm/tools/llvm-shlib/CMakeLists.txt b/llvm/tools/llvm-shlib/CMakeLists.txt
index aaaaaaaaaaaa1..bbbbbbbbbbbbb 100644
--- a/llvm/tools/llvm-shlib/CMakeLists.txt
+++ b/llvm/tools/llvm-shlib/CMakeLists.txt
@@ -36,7 +36,7 @@ if(LLVM_BUILD_LLVM_DYLIB)
   if (WIN32 OR CYGWIN)
     add_llvm_library(LLVM SHARED DISABLE_LLVM_LINK_LLVM_DYLIB SONAME ${INSTALL_WITH_TOOLCHAIN} ${SOURCES})
   else()
-    add_llvm_library(LLVM SHARED DISABLE_LLVM_LINK_LLVM_DYLIB OUTPUT_NAME LLVM ${INSTALL_WITH_TOOLCHAIN} ${SOURCES})
+    add_llvm_library(LLVM SHARED DISABLE_LLVM_LINK_LLVM_DYLIB OUTPUT_NAME LLVMpolyregion ${INSTALL_WITH_TOOLCHAIN} ${SOURCES})
     # Add symlink for backwards compatibility with old library name
     llvm_install_library_symlink(LLVM-${LLVM_VERSION_MAJOR}${LLVM_VERSION_SUFFIX} $<TARGET_FILE_NAME:LLVM> SHARED FULL_DEST COMPONENT LLVM)
   endif()
--
