if (NOT BIN)
    message(FATAL_ERROR "BIN not set")
endif ()
if (APPLE)
    execute_process(COMMAND otool -L ${BIN} OUTPUT_VARIABLE OUT RESULT_VARIABLE RC)
elseif (WIN32)
    execute_process(COMMAND dumpbin /DEPENDENTS ${BIN} OUTPUT_VARIABLE OUT RESULT_VARIABLE RC)
else ()
    execute_process(COMMAND ldd ${BIN} OUTPUT_VARIABLE OUT RESULT_VARIABLE RC)
endif ()
if (NOT RC EQUAL 0)
    message(FATAL_ERROR "Dependency listing failed for ${BIN} (rc=${RC}):\n${OUT}")
endif ()
if (OUT MATCHES "(libLLVM|libMLIR|libclang-cpp|libpoly[^/]*\\.(so|dylib|dll))")
    message(FATAL_ERROR "Forbidden polyregion/llvm DSO in deps of ${BIN}:\n${OUT}")
endif ()
message(STATUS "Deps OK: ${BIN}")
